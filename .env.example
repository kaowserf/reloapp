# Copy to .env.local for local dev, and set these in Vercel → Settings → Environment Variables.
# Never commit real keys — .env.local is gitignored.

# --- Required ---

# Google Gemini API key — powers /api/analyze (website scan, script + 20 video ideas)
# and the Veo cinematic route (/api/generate-video). Get one at https://aistudio.google.com
# NOTE: Veo video generation needs BILLING ENABLED; the free tier quota is very small.
GEMINI_API_KEY=your_gemini_api_key_here

# HeyGen API key — powers avatar video generation (/api/heygen-video)
# and the 1000+ avatar catalog (/api/heygen-avatars). Get one at https://app.heygen.com
HEYGEN_API_KEY=your_heygen_api_key_here

# --- Optional (have sensible defaults) ---

# Max videos a single user (per IP) can generate per day. Default: 5
HEYGEN_DAILY_LIMIT=5

# Max spoken length of a generated video, in seconds. Default: 30
HEYGEN_MAX_SECONDS=30

# Daily cap for the Veo cinematic route (/api/generate-video). Default: 5
VIDEO_DAILY_LIMIT=5

# Admin dashboard password. NEXT_PUBLIC_ = exposed to the browser, so this is
# convenience gating only, not real security.
NEXT_PUBLIC_ADMIN_PASSWORD=change_me
